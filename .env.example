# Supabase — copy to .env.local and fill in real values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev toggle — set true to bypass subscription checks (all users appear as premium)
NEXT_PUBLIC_MOCK_SUBSCRIPTION=false
NEXT_PUBLIC_INTRO_VIDEO_ID=

# AI — fill in when integrating real AI
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Stripe — fill in when integrating payments
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
